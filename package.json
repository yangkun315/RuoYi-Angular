{
  "name": "ruo-yi-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng s -o",
    "build": "ng b",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "hmr": "ng s -o --hmr",
    "analyze": "ng b --source-map",
    "analyze:view": "source-map-explorer dist/**/*.js --no-border-checks",
    "test-coverage": "ng test -c coverage --coverage --watch=false",
    "color-less": "ng-alain-plugin-theme -t=colorLess",
    "theme": "ng-alain-plugin-theme -t=themeCss",
    "icon": "ng g ng-alain:plugin icon",
    "lint": "npm run lint:ts && npm run lint:style",
    "lint:ts": "ng lint",
    "lint:style": "npx stylelint \\\"src/**/*.less\\\" --fix",
    "prepare": "husky install"
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@delon/abc": "^21.0.5",
    "@delon/acl": "^21.0.5",
    "@delon/auth": "^21.0.5",
    "@delon/cache": "^21.0.5",
    "@delon/chart": "^21.0.5",
    "@delon/form": "^21.0.5",
    "@delon/mock": "^21.0.5",
    "@delon/theme": "^21.0.5",
    "@delon/util": "^21.0.5",
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@juggle/resize-observer": "^3.4.0",
    "@ngx-loading-bar/core": "^7.0.1",
    "@ngx-loading-bar/router": "^7.0.1",
    "@ngxs/router-plugin": "^21.0.0",
    "@ngxs/store": "^21.0.0",
    "crypto-js": "^4.2.0",
    "echarts": "^5.5.0",
    "file-saver": "^2.0.5",
    "flv.js": "^1.6.2",
    "lodash": "^4.17.21",
    "lottie-web": "^5.12.2",
    "moment": "^2.30.1",
    "ng-alain": "^21.0.5",
    "ng-zorro-antd": "^21.0.2",
    "ngx-echarts": "^18.0.0",
    "ngx-image-cropper": "^9.1.6",
    "ngx-lottie": "^10.0.0",
    "ngx-perfect-scrollbar": "^10.1.0",
    "ngx-permissions": "^17.0.0",
    "pdfjs-dist": "^4.0.0",
    "rxjs": "~7.8.0",
    "screenfull": "^6.0.2",
    "tslib": "^2.3.0",
    "video.js": "^8.10.0",
    "xterm": "^5.1.0",
    "xterm-addon-fit": "^0.7.0",
    "xterm-addon-web-links": "^0.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@delon/testing": "^21.0.5",
    "@ng-util/monaco-editor": "^21.1.0",
    "@playwright/test": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@typescript-eslint/utils": "^8.54.0",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.16",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-jsdoc": "~62.5.0",
    "eslint-plugin-prefer-arrow": "~1.2.3",
    "eslint-plugin-prettier": "~5.5.5",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "ng-alain": "^21.0.5",
    "ng-alain-plugin-theme": "^18.0.0",
    "ngx-tinymce": "^21.0.0",
    "prettier": "^3.8.1",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^17.1.0",
    "stylelint-config-clean-order": "^8.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-order": "^7.0.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.54.0",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "(src)/**/*.{html,ts}": [
      "eslint --fix"
    ],
    "(src)/**/*.less": [
      "npm run lint:style"
    ]
  }
}
